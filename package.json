{
    "name": "@mikaelcarrara/underlith",
    "version": "2.1.1",
    "description": "Governable design tokens for teams building across frameworks and platforms.",
    "author": "Mikael Carrara",
    "license": "MIT",
    "bin": {
        "underlith": "./bin/underlith.js"
    },
    "main": "index.js",
    "preferGlobal": true,
    "engines": {
        "node": ">=18"
    },
    "scripts": {
        "dev": "node bin/underlith.js",
        "build:tokens": "node scripts/generate-tokens.js",
        "build:css": "node scripts/build-css.js",
        "build": "npm run build:tokens && npm run build:css",
        "test": "echo \"No tests yet\""
    },
    "keywords": [
        "design-system",
        "design-tokens",
        "css-variables",
        "design-token-governance",
        "frontend-infrastructure",
        "ui-governance"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/mikaelcarrara/underlith"
    },
    "homepage": "https://github.com/mikaelcarrara/underlith",
    "bugs": {
        "url": "https://github.com/mikaelcarrara/underlith/issues"
    },
    "files": [
        "bin",
        "scripts",
        "src",
        "index.js",
        "tokens.json",
        "underlith.config.js",
        "README.md"
    ]
}